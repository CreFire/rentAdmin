# build stage
FROM golang:1.22-alpine AS builder
WORKDIR /app

RUN apk add --no-cache gcc musl-dev
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o server ./cmd/api

# run stage
FROM alpine:3.20
WORKDIR /app

# sqlite + ca certs
RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /app/server /app/server

# 数据目录（SQLite 文件会放这里）
RUN mkdir -p /data
ENV SQLITE_PATH=/data/app.db
ENV ADDR=:8080

EXPOSE 8080
CMD ["/app/server"]
