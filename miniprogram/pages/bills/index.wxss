.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.sub {
  margin-top: 12rpx;
  color: #6b7280;
}

.bill .row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.date {
  font-weight: 600;
}

.status {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.status-paid {
  background: #d1fae5;
  color: #166534;
}

.status-unpaid {
  background: #fee2e2;
  color: #991b1b;
}

.status-partial {
  background: #fef3c7;
  color: #92400e;
}

.unpaid {
  color: #dc2626;
}
